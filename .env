APP_NAME=SecureRegistration
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=secure_registration
DB_USERNAME=root
DB_PASSWORD=

# Security Keys
APP_KEY=base64:GENERATE_RANDOM_KEY
SESSION_SECRET=super_secure_session_key

# Session Config
SESSION_LIFETIME=120
SESSION_SECURE=false

# Logging
LOG_LEVEL=debug

# Future Integration
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
